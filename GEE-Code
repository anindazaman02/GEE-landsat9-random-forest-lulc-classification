var L9 = ee.ImageCollection("LANDSAT/LC09/C02/T1_L2")  

var image = L9.filterBounds(aoi)
            .filterDate('2024-01-10', '2024-03-25')
            .filterMetadata ('CLOUD_COVER','less_than',2)
            .mean()
            .clip(aoi)


Map.addLayer(image, imageVisParam, 'True Color');

var classname = water.merge(vegetation).merge(urban);
print(classname);

var bands = ['SR_B2', 'SR_B3', 'SR_B4', 'SR_B5', 'SR_B6', 'SR_B7'];
var training = image.select(bands).sampleRegions({
  collection: classname,
  properties: ['landcover'],
  scale: 30
});

print(training);


var classifier = ee.Classifier.smileRandomForest(100).train({
  features: training,
  classProperty: 'landcover',
  inputProperties: bands
});

var classified = image.select(bands).classify(classifier);
Map.centerObject(classname, 11);
Map.addLayer(classified,
{min: 0, max: 2, palette: ['#0e58bd', '#89d209', '#9bb3f0']},
'Random Forest Classification');

// Accuracy assessment

var random_column = training.randomColumn();
var split = 0.7; // Define the split ratio
var trainingData = random_column.filter(ee.Filter.lt('random', split)); // 70% for training
var testingData = random_column.filter(ee.Filter.gte('random', split)); // 30% for testing

print('Training Data:', trainingData);
print('Testing Data:', testingData);

// Train classifier on training data
var trainedClassifier = ee.Classifier.smileRandomForest(100).train({
  features: trainingData,
  classProperty: 'landcover',
  inputProperties: bands
});

// Classify image
var classifiedImage = image.select(bands).classify(trainedClassifier);

// Test accuracy
var testAccuracy = testingData.classify(trainedClassifier);
var confusionMatrix = testAccuracy.errorMatrix('landcover', 'classification');

print('Confusion Matrix:', confusionMatrix);
print('Overall Accuracy:', confusionMatrix.accuracy());
print('Kappa Coefficient:', confusionMatrix.kappa());


